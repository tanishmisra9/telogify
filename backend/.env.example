# Postgres (local dev default; Railway URL for deploy)
DATABASE_URL=postgresql://localhost:5432/telogify_dev

# LLM provider for the insight agent (openai | anthropic). Switch in .env, no code change.
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1

# Only required when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# Resend (required for send-digest; uses shared sender pre-domain-verification)
RESEND_API_KEY=
RESEND_FROM=Telogify <onboarding@resend.dev>

# FastF1 on-disk cache directory
FASTF1_CACHE=.fastf1_cache

# Base URL the email CTA links back to
WEB_BASE_URL=http://localhost:5173
